@startuml

class Program{
    #_entryPrompts: list
    #_journalPrompts: list
    -_filename: string
    -OpenJournal(): string
    -DisplayJournal(): void
    -ModifyJournal(): void
    -WriteJournal(): void
}

class Journal{
    +_entries: string
    +_entry: string
    +AddEntry(prompt: string): void
}

class Prompt{
    +_prompts: list
    +DisplayPrompts(): void
    +GetRandomPrompt(): string
}

Prompt -> Program
Journal -> Program

@enduml