@startuml

class Program
{
    -_journal: string
    -_journalPrompt: string
    -OpenJournal(): void
    -DisplayJournal(): void
    -ModifyJournal(): void
    -WriteJournal(): void
}

class Journal
{
    +_entries: string
    +_entry: string
    +DisplayEntries(): void
    +AddEntry(): void
}

class Entry
{
    +_timeAndDate: string
    +_entryPrompt: string
    +_entry: string
    +GetEntry(): string
}

class Prompt
{
    +_prompts: List<string>
    +ListAllPrompts(): void
    +GenerateRandomPrompt(): string
}

Program <|.. Journal
Journal *-- Entry
Program <|.. Prompt
Entry <|.. Prompt


@enduml