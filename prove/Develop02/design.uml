@startuml

class Program{
    #entryPrompts: list
    #journalPrompts: list
    -GetJournal(in file): string
    -DisplayJournal(in entries: string): void
    -ModifyJournal(): string
    -WriteJournal(in entries: string): void
}

class Journal{
    +entries: string
    +entry: string
    +AddEntry(): string
}

class Prompt{
    +prompts: list
    +DisplayPrompts(): string
    +DisplayRandomPrompt(): string
}

Prompt -> Program
Journal -> Program

@enduml