@startuml design

class Program
{
    
}

class Prompt
{
    -_prompts : List<string>
    +Prompt(in prompts : List<string>)
    +DisplayPrompt(in index : int) : void
    +DisplayRandomPrompt() : void
    +ListAllPrompts() : void
}

class Activity
{
    -_name : string
    -_startingMessage : string
    -_completionMessage : string
    -_completionMessageDuration : int
    ~Activity(name : string, startingMessage : string, completionMessage : string)
    ~Start() : void
    ~End() : void
    ~SetCompletionMessageDuration(seconds : int) : void
    ~GetCompletionMessageDuration() : int
}

class BreathingActivity
{
    -_activityDuration : int
    +BreathingActivity(name : string, startingMessage : string, completionMessage : string)
    -Main() : void
    -AskForDuration() : void
    -PauseToGetReady() : void
    -Breathe() : void
    -BreatheIn() : void
    -BreathOut() : void
}

