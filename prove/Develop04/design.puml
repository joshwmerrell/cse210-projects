class Timer
{
    -_seconds : int
    -_message : string
    ~Timer(seconds : int, message : string)
    ~GetSeconds() : int
    ~GetMessage() : string
}

class CountdownTimer
{
    +CountdownTimer(seconds : int, message : string)
}

class AnimatedTimer
{
    -_animationSteps : List<string>
    +Animatedimer(seconds : int, message : string, animationStepsCombinedWithCommas : string)
    -SetAnimationSteps(stepsCombinedWithCommas : string) : void
    -RunTimer() : void
}

