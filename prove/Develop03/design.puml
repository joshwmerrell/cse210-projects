@startuml design

class Program
{
    _scriptures : List<Scripture>
    _memorizingScripture : bool
    _nextScripture : bool
    SetScripturesList() : void
    ClearConsole() : void
    DisplayScripture() : void
    QuitNextOrContinueProgram() : void
    NextScripture() : void
    RemoveWords() : void
}

class Scripture
{
    -_reference : Reference
    -_words : List<Word>
    +Scripture(in reference : string, in scripture : string)
    +GetScripture() : string
    +BlankOutWords() : void
    +AmountOfVisibleWords() : int
    -AmountOfWords() : int
    -GetRandomInt(in maxInt : int, in minInt : int) : int
}

class Word
{
    -_word : string
    -_isBlank : bool
    +Word(in word : string)
    +GetWord() : string
    +MakeBlank() : void
    +IsVisible() : bool
}

class Reference
{
    -_book : string
    -_chapter : string
    -_verses : string
    +Reference(in reference : string)
    +GetReference() : string
}

Program <|.. Scripture
Scripture <|.. Reference
Scripture <|.. Word

@enduml