@startuml design

class Program
{
    -_continueProgram : bool
    -_points : Points
    -_goals : Goals
    -_menuOptions : List<string>
    ClearConsole() : void
    DisplayPoints() : void
    ListMenu() : void
    ChooseOption() : void
    CreateNewGoal() : void
    ListGoals() : void
    SaveGoals() : void
    LoadGoals() : void
    RecordEvent() : void
    Quit() : void
}

class Points
{
    -_amount : int
    +Points()
    +AddPoints() : void
    +GetPoints() : int
}

class Goals
{
    -_goals : List<Goal>
    +Goals()
    +SetGoal() : void
    +CreateGoal() : void
    +ListGoals() : void
    +LoadGoals() : void
    +RecordEvent(in goalNumber : int) : int
    -GoalIsFinished(in goalIndex : int) : bool
    -MarkGoalCompleted(in goalIndex : int) : void
    -GetPoints(in goalIndex : int) : int
}

class File
{
    -_fileName : string
    -_goalsInFile : List<string>
    +File(in fileName : string)
    -GetFile() : string
    -FileFound() : bool
    -SetGoals() : void
    +GetGoals() : List<Goal>
    +WriteToFile(in goals : List<Goal>) : void
}

abstract Goal
{
    -_name : string
    -_description : string
    -_points : int
    -_isCompleted : bool
    +Goal(in name : string, in description : string, in points : int)
    +GetGoal() : string
    +GetPoints() : int
    +IsFinished() : bool
}

class SimpleGoal
{
    +SimpleGoal(in name : string, in description : string, in points : int)
}

class ChecklistGoal
{
    -_amountToComplete : int
    -_amountAccomplished : int
    -_bonusPoints : int
    +ChecklistGoal(in name : string, in description : string, in points : int, in amountToComplete : int, in bonusPoints : int)
    +override GetPoints() : int
    -GetBonusPoints() : int
}

class EternalGoal
{
    +EternalGoal(in name : string, in description : string, in points : int)
    +override IsFinished() : bool
}

Program <-- Points
Program <-- Goals
Goals <-- Goal
Goals <-- File
Goal <|-- SimpleGoal
Goal <|-- ChecklistGoal
Goal <|-- EternalGoal

@enduml