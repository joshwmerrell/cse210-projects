@startuml finalDesign

class Program
{
    _volumes : List<Scripture>
    _books : List<Scripture>
    _chapters : List<Scripture>
    _verses : List<Scripture>
    _commands : List<string>
    SetScriptures() : void
    DisplayInto() : void
    DisplayMenu() : void
    Search() : void
    GetInquiry() : string
    CommandAndSearchingForArePresent() : bool
    CommandIsPresent() : bool
    GetCommand(inquiry : string) : string
    GetSearchingFor(inquiry : string) : string
}

abstract Scripture
{
    -_number : int
    -_name : string
    +Scripture(scriptureCsvLine : string)
    -SetNumber() : void
    -SetName() : void
    ~SetScripture() : void
    +GetNumber() : int
    +GetName() : string
    ~DisplaySearchResult() : void
}

class Volume
{
    -_booksNames : List<string>
    +Volume(volumeCsvList : List<string>)
    ~SetScripture() : void
    ~DisplaySearchResult() : void
}

class Book
{
    -_verseAmountInEachChapter : List<int>
    +Book(bookCsvList : List<string>)
    ~SetScripture() : void
    ~DisplaySearchResult() : void
}

class Chapter
{
    -_verses : List<string>
    +Chapter(chapterCsvList : List<string>)
    ~SetScripture() : void
    ~DisplaySearchResult() : void
}

class Verse
{
    -_verse : string
    +Verse(verseCsvList : string)
    ~SetScripture() : void
    ~DisplaySearchResult() : void
}

@enduml